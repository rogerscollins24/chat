# LeadPulse Backend Configuration
# Copy this file to .env and fill in your actual values

# Database - PostgreSQL (required for production)
DATABASE_URL=postgresql://user:password@localhost:5432/leadpulse_db

# Environment
ENVIRONMENT=development

# Security - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=generate-a-random-32-character-string-here-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# CORS - Whitelist your domain(s)
# For production, use exact domains: https://ranga.com,https://admin.ranga.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
